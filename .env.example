# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.

# Orchestrator (LangGraph + ChatOpenAI -> AI/ML API, OpenAI-compatible)
LLM_BASE_URL=https://api.aimlapi.com/v1
LLM_API_KEY=<aiml key>
ORCHESTRATOR_MODEL=gpt-4o

# Specialists (CrewAI -> LiteLLM -> AI/ML API, provider route "aiml/")
AIML_API_KEY=<aiml key>
SPECIALIST_MODEL=aiml/gpt-4o-mini
# AIML_API_BASE=https://api.aimlapi.com/v2   # only if a CrewAI call 400s on the endpoint

# Band platform
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
THENVOI_REST_URL=https://app.band.ai

# Watchers (REST, send-only) + room
EVERGREEN_ROOM_ID=<room uuid>
MARKET_WATCHER_API_KEY=<market watcher agent key>     # external/competitor events
METRICS_WATCHER_API_KEY=<metrics watcher agent key>   # internal MRR/churn events
                                                      # (falls back to MARKET_WATCHER_API_KEY if unset)
ORCHESTRATOR_NAME=Orchestrator

# Simulated clock (clock/sim_clock.py — drives the watchers; read by record_decision)
SIM_SECONDS_PER_DAY=5
SIM_START_DAY=1
# SIM_CLOCK_STATE_FILE=clock/clock_state.json   # default; persisted sim-day

# Fake data source (core/sources/fake_stripe.py) — deterministic timeline
FAKE_DATA_SEED=42
PLANTED_CHURN_DAY=12
# PLANTED_STARTER_CHURN=300
# Metrics watcher detection (defaults shown)
# METRICS_BASELINE_DAYS=7
# METRICS_MIN_STDDEV_PCT=0.005
# MRR_DROP_PCT=0.10
# MRR_Z=3.0
